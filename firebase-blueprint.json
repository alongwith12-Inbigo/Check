{
  "entities": {
    "Evaluation": {
      "title": "Evaluation",
      "description": "Evaluation scores uploaded by teacher",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Evaluation Title"
        },
        "subject": {
          "type": "string",
          "description": "Subject Name"
        },
        "round": {
          "type": "string",
          "description": "Evaluation Round"
        },
        "evaluationDetailName": {
          "type": "string",
          "description": "Detail evaluation name"
        },
        "headers": {
          "type": "array",
          "description": "Array of headers"
        },
        "rows": {
          "type": "array",
          "description": "Array of student data rows"
        },
        "uploadedAt": {
          "type": "string",
          "description": "Upload timestamp string"
        }
      },
      "required": ["title", "headers", "rows"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Differentiated teachers info",
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "3-digit teacher code"
        },
        "name": {
          "type": "string",
          "description": "Teacher name"
        }
      },
      "required": ["code", "name"]
    },
    "SubjectSettings": {
      "title": "SubjectSettings",
      "description": "Subject overall max score settings managed by teacher",
      "type": "object",
      "properties": {
        "teacherCode": {
          "type": "string",
          "description": "3-digit teacher code"
        },
        "subject": {
          "type": "string",
          "description": "Subject name"
        },
        "maxScore": {
          "type": "string",
          "description": "Overall evaluation max score for the subject"
        }
      },
      "required": ["teacherCode", "subject", "maxScore"]
    },
    "TeacherSettings": {
      "title": "TeacherSettings",
      "description": "Settings for each teacher, e.g., signature enabled",
      "type": "object",
      "properties": {
        "teacherCode": {
          "type": "string",
          "description": "Differentiated teacher code"
        },
        "signatureEnabled": {
          "type": "boolean",
          "description": "Whether student signature feature is enabled"
        }
      },
      "required": ["teacherCode", "signatureEnabled"]
    },
    "StudentSignature": {
      "title": "StudentSignature",
      "description": "Signature submitted by student",
      "type": "object",
      "properties": {
        "teacherCode": {
          "type": "string",
          "description": "Teacher code"
        },
        "subject": {
          "type": "string",
          "description": "Subject name"
        },
        "studentId": {
          "type": "string",
          "description": "Student school ID"
        },
        "studentName": {
          "type": "string",
          "description": "Student name"
        },
        "signatureDataUrl": {
          "type": "string",
          "description": "Base64 signature image representation"
        },
        "signedAt": {
          "type": "string",
          "description": "Signed timestamp"
        }
      },
      "required": ["teacherCode", "subject", "studentId", "studentName", "signatureDataUrl", "signedAt"]
    },
    "RegisteredStudent": {
      "title": "RegisteredStudent",
      "description": "Student roster uploaded by Admin containing credentials for logins",
      "type": "object",
      "properties": {
        "studentId": {
          "type": "string",
          "description": "5-digit Student ID"
        },
        "name": {
          "type": "string",
          "description": "Student Name"
        },
        "birthdate": {
          "type": "string",
          "description": "8-digit birthdate string"
        },
        "password": {
          "type": "string",
          "description": "Student-configured custom password"
        }
      },
      "required": ["studentId", "name", "birthdate"]
    },
    "ExcelUpload": {
      "title": "ExcelUpload",
      "description": "Metadata for uploaded excel file rosters",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique ID / Type (e.g. students or teachers)"
        },
        "fileName": {
          "type": "string",
          "description": "The name of the uploaded Excel file"
        },
        "uploadedAt": {
          "type": "string",
          "description": "ISO timestamp of when it was uploaded"
        },
        "recordCount": {
          "type": "number",
          "description": "Amount of records imported"
        }
      },
      "required": ["id", "fileName", "uploadedAt", "recordCount"]
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "description": "General system configuration and document templates",
      "type": "object",
      "properties": {
        "fileName": {
          "type": "string",
          "description": "File name of the uploaded excel template"
        },
        "fileBase64": {
          "type": "string",
          "description": "Base64 representation of the excel template"
        },
        "uploadedAt": {
          "type": "string",
          "description": "Local date string of the upload"
        }
      },
      "required": ["fileName", "fileBase64", "uploadedAt"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "General application settings",
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "description": "Privacy policy text content or other general settings"
        },
        "updatedAt": {
          "type": "string",
          "description": "ISO timestamp of when it was updated"
        }
      },
      "required": ["content"]
    }
  },
  "firestore": {
    "/evaluation/{evalId}": {
      "schema": "Evaluation",
      "description": "General evaluation table containing student lists and settings for each teacher or active default"
    },
    "/teachers/{teacherCode}": {
      "schema": "Teacher",
      "description": "Array/Collection of differentiated teachers managed by general school administrator"
    },
    "/subjectSettings/{settingId}": {
      "schema": "SubjectSettings",
      "description": "Contains subject-level overall evaluation max score settings"
    },
    "/teacherSettings/{teacherCode}": {
      "schema": "TeacherSettings",
      "description": "Teacher-level settings like enabling student signatures"
    },
    "/signatures/{signatureId}": {
      "schema": "StudentSignature",
      "description": "Student signatures for their scores in each subject"
    },
    "/students/{studentId}": {
      "schema": "RegisteredStudent",
      "description": "School-wide student registry for verification and authentication details"
    },
    "/excelUploads/{uploadId}": {
      "schema": "ExcelUpload",
      "description": "Metadata recording the active/latest excel roster file uploaded by admin"
    },
    "/systemConfig/{configId}": {
      "schema": "SystemConfig",
      "description": "System configs and shared file templates like Excel forms"
    },
    "/appSettings/{settingId}": {
      "schema": "AppSettings",
      "description": "General application settings like privacy policies"
    }
  }
}
